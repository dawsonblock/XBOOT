# XBOOT Docker Environment Configuration
# Copy this file to .env and customize for your deployment

# =============================================================================
# Network Configuration
# =============================================================================

# Port to expose zeroboot API on host
XBOOT_PORT=8080

# =============================================================================
# Paths
# =============================================================================

# Directory containing secrets (api_keys.json, pepper, etc.)
# This directory will be mounted read-only into the container
XBOOT_SECRETS_DIR=./secrets

# Directory for writable state (logs, request logs, runtime data)
# This directory will be mounted read-write into the container
XBOOT_STATE_DIR=./state

# =============================================================================
# Authentication
# =============================================================================

# Auth mode: 'prod' (hashed keys + pepper) or 'dev' (plaintext keys)
ZEROBOOT_AUTH_MODE=prod

# =============================================================================
# Security Settings
# =============================================================================

# Require template manifest hashes
ZEROBOOT_REQUIRE_TEMPLATE_HASHES=true

# Require template manifest signatures (set to true in production with signing)
ZEROBOOT_REQUIRE_TEMPLATE_SIGNATURES=false

# Trusted proxy IPs (comma-separated, for X-Forwarded-For handling)
ZEROBOOT_TRUSTED_PROXIES=

# =============================================================================
# Firecracker Version Pinning
# =============================================================================

# Expected Firecracker version
ZEROBOOT_ALLOWED_FIRECRACKER_VERSION=1.12.0

# Expected Firecracker binary SHA256 (leave empty to skip check)
# Get this value with: sha256sum $(which firecracker)
ZEROBOOT_ALLOWED_FC_BINARY_SHA256=

# =============================================================================
# Operational Settings
# =============================================================================

# Skip startup verification (useful for development, NOT for production)
VERIFY_ON_STARTUP=true

# Health check cache TTL in seconds
ZEROBOOT_HEALTH_CACHE_TTL_SECS=10

# Minimum free disk space in bytes (512MB default)
ZEROBOOT_MIN_FREE_BYTES=536870912

# Minimum free inodes
ZEROBOOT_MIN_FREE_INODES=10000

# =============================================================================
# Request Limits
# =============================================================================

# Maximum request body size in bytes (256KB default)
ZEROBOOT_MAX_REQUEST_BODY_BYTES=262144

# Maximum code size in bytes (128KB default)
ZEROBOOT_MAX_CODE_BYTES=131072

# Maximum stdin size in bytes (64KB default)
ZEROBOOT_MAX_STDIN_BYTES=65536

# Maximum stdout size in bytes (64KB default)
ZEROBOOT_MAX_STDOUT_BYTES=65536

# Maximum stderr size in bytes (64KB default)
ZEROBOOT_MAX_STDERR_BYTES=65536

# Maximum total output size in bytes (96KB default)
ZEROBOOT_MAX_TOTAL_OUTPUT_BYTES=98304

# Maximum batch size
ZEROBOOT_MAX_BATCH_SIZE=16

# Maximum timeout in seconds
ZEROBOOT_MAX_TIMEOUT_SECS=30

# Maximum concurrent requests
ZEROBOOT_MAX_CONCURRENT_REQUESTS=32

# =============================================================================
# Logging
# =============================================================================

# Log code in request logs (set to false in production)
ZEROBOOT_LOG_CODE=false
